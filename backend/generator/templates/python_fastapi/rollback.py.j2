#!/usr/bin/env python
"""
Database migration rollback script for {{ service_name }}
"""
import asyncio
import sys

{% if config.database.database_type.value == "postgresql" -%}
import asyncpg

async def rollback_migration(version: int):
    """Rollback migration to specified version"""
    conn = await asyncpg.connect("{{ '${DATABASE_URL}' }}")
    
    try:
        # Get current version
        current = await conn.fetchval("""
            SELECT MAX(version) FROM schema_migrations
        """)
        
        if not current or current < version:
            print(f"Cannot rollback: current version is {current}")
            return False
        
        # Load and execute rollback
        from database.migrations import migration_001
        
        if version == 0:  # Rollback all
            print("Rolling back migration 001...")
            await migration_001.downgrade(conn)
        
        print(f"Rollback to version {version} complete")
        return True
    
    finally:
        await conn.close()

{% elif config.database.database_type.value == "mongodb" -%}
from motor.motor_asyncio import AsyncIOMotorClient

async def rollback_migration(version: int):
    """Rollback migration to specified version"""
    client = AsyncIOMotorClient("{{ '${DATABASE_URL}' }}")
    db = client["{{ service_name_snake }}"]
    
    try:
        # Get current version
        current_doc = await db.schema_migrations.find_one(sort=[("version", -1)])
        current = current_doc["version"] if current_doc else 0
        
        if current < version:
            print(f"Cannot rollback: current version is {current}")
            return False
        
        # Load and execute rollback
        from database.migrations import migration_001
        
        if version == 0:  # Rollback all
            print("Rolling back migration 001...")
            await migration_001.downgrade(db)
        
        print(f"Rollback to version {version} complete")
        return True
    
    finally:
        client.close()

{% endif -%}

async def main():
    if len(sys.argv) < 2:
        print("Usage: python rollback.py <version>")
        print("  version 0: rollback all migrations")
        sys.exit(1)
    
    version = int(sys.argv[1])
    success = await rollback_migration(version)
    sys.exit(0 if success else 1)


if __name__ == "__main__":
    asyncio.run(main())
