apiVersion: v1
kind: Secret
metadata:
  name: {{ service_name }}-secrets
  namespace: default
type: Opaque
stringData:
  # Database credentials (populate these)
  {% if config.database.database_type.value == "postgresql" -%}
  DATABASE_URL: "postgresql://user:password@postgres:5432/{{ service_name_snake }}"
  {% elif config.database.database_type.value == "mongodb" -%}
  DATABASE_URL: "mongodb://user:password@mongodb:27017"
  {% elif config.database.database_type.value == "redis" -%}
  REDIS_URL: "redis://:password@redis:6379/0"
  {% endif -%}
  
  # Security credentials
  {% if config.security.auth_type.value in ["api_key", "both"] -%}
  API_KEYS: "your-api-key-1,your-api-key-2"
  {% endif -%}
  {% if config.security.auth_type.value in ["jwt", "both"] -%}
  JWT_SECRET: "your-secret-key-change-this"
  {% endif -%}
