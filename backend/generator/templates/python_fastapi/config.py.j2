"""
Configuration management with environment variable validation
"""
import os
from typing import List, Optional
from pydantic import Field
from pydantic_settings import BaseSettings, SettingsConfigDict


class Settings(BaseSettings):
    """Application settings with validation"""
    
    # Service Metadata
    SERVICE_NAME: str = "{{ service_name }}"
    VERSION: str = "{{ version }}"
    ENVIRONMENT: str = Field(default="development", pattern="^(development|staging|production)$")
    
    # Server Configuration
    HOST: str = "0.0.0.0"
    PORT: int = {{ port }}
    API_PREFIX: str = "{{ config.metadata.api_prefix }}"
    
    # Security
    {% if config.security.auth_type.value in ["api_key", "both"] -%}
    API_KEYS: List[str] = Field(default_factory=lambda: os.getenv("API_KEYS", "changeme").split(","))
    API_KEY_HEADER: str = "{{ config.security.api_key_header }}"
    {% endif -%}
    {% if config.security.auth_type.value in ["jwt", "both"] -%}
    JWT_SECRET: str = Field(default="changeme-secret-key")
    JWT_ALGORITHM: str = "HS256"
    JWT_EXPIRY_HOURS: int = {{ config.security.jwt_expiry_hours }}
    {% endif -%}
    
    # Rate Limiting
    RATE_LIMIT_PER_MINUTE: int = {{ config.security.rate_limit_per_minute }}
    RATE_LIMIT_BURST: int = {{ config.security.rate_limit_burst }}
    
    # CORS
    CORS_ORIGINS: List[str] = {{ config.security.cors_origins }}
    
    # Database
    {% if config.database.database_type.value == "postgresql" -%}
    DATABASE_URL: str = Field(default="postgresql://user:password@localhost:5432/{{ service_name_snake }}")
    {% elif config.database.database_type.value == "mongodb" -%}
    DATABASE_URL: str = Field(default="mongodb://localhost:27017")
    DATABASE_NAME: str = "{{ service_name_snake }}"
    {% elif config.database.database_type.value == "redis" -%}
    REDIS_URL: str = Field(default="redis://localhost:6379/0")
    {% endif -%}
    DB_POOL_SIZE: int = {{ config.database.connection_pool_size }}
    DB_TIMEOUT: int = {{ config.database.connection_timeout }}
    
    # Observability
    LOG_LEVEL: str = "{{ config.observability.log_level }}"
    ENABLE_METRICS: bool = {{ config.observability.enable_prometheus | lower }}
    ENABLE_TRACING: bool = {{ config.observability.enable_tracing | lower }}
    METRICS_PORT: int = {{ config.observability.metrics_port }}
    
    # Feature Flags
    ENABLE_API_DOCS: bool = {{ config.enable_api_docs | lower }}
    
    model_config = SettingsConfigDict(
        env_file=".env",
        env_file_encoding="utf-8",
        case_sensitive=True,
        extra="ignore",
    )
    
    def is_production(self) -> bool:
        """Check if running in production"""
        return self.ENVIRONMENT == "production"
    
    def is_development(self) -> bool:
        """Check if running in development"""
        return self.ENVIRONMENT == "development"


# Global settings instance
settings = Settings()

# Validate critical settings on import
if settings.is_production():
    {% if config.security.auth_type.value in ["api_key", "both"] -%}
    if "changeme" in settings.API_KEYS:
        raise ValueError("API_KEYS must be changed in production")
    {% endif -%}
    {% if config.security.auth_type.value in ["jwt", "both"] -%}
    if settings.JWT_SECRET == "changeme-secret-key":
        raise ValueError("JWT_SECRET must be changed in production")
    {% endif -%}
