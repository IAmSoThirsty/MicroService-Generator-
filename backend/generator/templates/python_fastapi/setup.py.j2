from setuptools import setup, find_packages

setup(
    name="{{ service_name }}",
    version="{{ version }}",
    description="{{ description }}",
    author="{{ author }}",
    packages=find_packages(exclude=["tests", "tests.*"]),
    python_requires=">=3.11",
    install_requires=[
        # See requirements.txt for pinned versions
    ],
    extras_require={
        "dev": [
            "pytest",
            "pytest-asyncio",
            "pytest-cov",
            "ruff",
            "mypy",
            "black",
            "isort",
        ],
    },
    entry_points={
        "console_scripts": [
            "{{ service_name_snake }}=app.main:main",
        ],
    },
)
