{% if config.kubernetes.enable_network_policy -%}
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: {{ service_name }}
  namespace: default
spec:
  podSelector:
    matchLabels:
      app: {{ service_name }}
  policyTypes:
  - Ingress
  - Egress
  ingress:
  # Allow traffic from ingress controller
  - from:
    - namespaceSelector:
        matchLabels:
          name: ingress-nginx
    ports:
    - protocol: TCP
      port: {{ port }}
  # Allow Prometheus scraping
  - from:
    - namespaceSelector:
        matchLabels:
          name: monitoring
    ports:
    - protocol: TCP
      port: {{ port }}
  egress:
  # Allow DNS
  - to:
    - namespaceSelector:
        matchLabels:
          name: kube-system
    ports:
    - protocol: UDP
      port: 53
  # Allow database access
  {% if config.database.database_type.value == "postgresql" -%}
  - to:
    - podSelector:
        matchLabels:
          app: postgres
    ports:
    - protocol: TCP
      port: 5432
  {% elif config.database.database_type.value == "mongodb" -%}
  - to:
    - podSelector:
        matchLabels:
          app: mongodb
    ports:
    - protocol: TCP
      port: 27017
  {% elif config.database.database_type.value == "redis" -%}
  - to:
    - podSelector:
        matchLabels:
          app: redis
    ports:
    - protocol: TCP
      port: 6379
  {% endif -%}
  # Allow HTTPS external traffic
  - to:
    - namespaceSelector: {}
    ports:
    - protocol: TCP
      port: 443
{% endif -%}
