# Environment Configuration
ENVIRONMENT=development

# Service
SERVICE_NAME={{ service_name }}
VERSION={{ version }}
HOST=0.0.0.0
PORT={{ port }}

# Database
{% if config.database.database_type.value == "postgresql" -%}
DATABASE_URL=postgresql://user:password@localhost:5432/{{ service_name_snake }}
{% elif config.database.database_type.value == "mongodb" -%}
DATABASE_URL=mongodb://localhost:27017
DATABASE_NAME={{ service_name_snake }}
{% elif config.database.database_type.value == "redis" -%}
REDIS_URL=redis://localhost:6379/0
{% endif -%}
DB_POOL_SIZE={{ config.database.connection_pool_size }}
DB_TIMEOUT={{ config.database.connection_timeout }}

# Security
{% if config.security.auth_type.value in ["api_key", "both"] -%}
API_KEYS=dev-key-1,dev-key-2,dev-key-3
API_KEY_HEADER={{ config.security.api_key_header }}
{% endif -%}
{% if config.security.auth_type.value in ["jwt", "both"] -%}
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS={{ config.security.jwt_expiry_hours }}
{% endif -%}

# Rate Limiting
RATE_LIMIT_PER_MINUTE={{ config.security.rate_limit_per_minute }}
RATE_LIMIT_BURST={{ config.security.rate_limit_burst }}

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Observability
LOG_LEVEL={{ config.observability.log_level }}
ENABLE_METRICS={{ config.observability.enable_prometheus | lower }}
ENABLE_TRACING={{ config.observability.enable_tracing | lower }}
METRICS_PORT={{ config.observability.metrics_port }}

# Features
ENABLE_API_DOCS={{ config.enable_api_docs | lower }}
