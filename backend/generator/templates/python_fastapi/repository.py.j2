class Database:
    """Database connection manager"""
    
    def __init__(self):
        {% if config.database.database_type.value == "postgresql" -%}
        self.pool: Optional[Pool] = None
        {% elif config.database.database_type.value == "mongodb" -%}
        self.client: Optional[AsyncIOMotorClient] = None
        self.db: Optional[AsyncIOMotorDatabase] = None
        {% elif config.database.database_type.value == "redis" -%}
        self.redis: Optional[aioredis.Redis] = None
        {% elif config.database.database_type.value == "in_memory" -%}
        self.data: Dict[str, Any] = {}
        self.connected = False
        {% endif -%}
    
    async def connect(self):
        """Establish database connection"""
        try:
            {% if config.database.database_type.value == "postgresql" -%}
            self.pool = await asyncpg.create_pool(
                settings.DATABASE_URL,
                min_size=settings.DB_POOL_SIZE // 4,
                max_size=settings.DB_POOL_SIZE,
                command_timeout=settings.DB_TIMEOUT,
            )
            logger.info("PostgreSQL connection pool established")
            {% elif config.database.database_type.value == "mongodb" -%}
            self.client = AsyncIOMotorClient(
                settings.DATABASE_URL,
                maxPoolSize=settings.DB_POOL_SIZE,
                serverSelectionTimeoutMS=settings.DB_TIMEOUT * 1000,
            )
            self.db = self.client[settings.DATABASE_NAME]
            # Verify connection
            await self.client.admin.command('ping')
            logger.info("MongoDB connection established")
            {% elif config.database.database_type.value == "redis" -%}
            self.redis = await aioredis.from_url(
                settings.REDIS_URL,
                max_connections=settings.DB_POOL_SIZE,
            )
            logger.info("Redis connection established")
            {% elif config.database.database_type.value == "in_memory" -%}
            self.connected = True
            logger.info("In-memory database initialized")
            {% endif -%}
            
            DB_CONNECTIONS_ACTIVE.set(settings.DB_POOL_SIZE)
        
        except Exception as e:
            logger.error(f"Database connection failed: {e}")
            raise DatabaseError(f"Failed to connect to database: {e}", "connect")
    
    async def disconnect(self):
        """Close database connections"""
        try:
            {% if config.database.database_type.value == "postgresql" -%}
            if self.pool:
                await self.pool.close()
                logger.info("PostgreSQL connection pool closed")
            {% elif config.database.database_type.value == "mongodb" -%}
            if self.client:
                self.client.close()
                logger.info("MongoDB connection closed")
            {% elif config.database.database_type.value == "redis" -%}
            if self.redis:
                await self.redis.close()
                logger.info("Redis connection closed")
            {% elif config.database.database_type.value == "in_memory" -%}
            self.connected = False
            self.data.clear()
            logger.info("In-memory database cleared")
            {% endif -%}
            
            DB_CONNECTIONS_ACTIVE.set(0)
        
        except Exception as e:
            logger.error(f"Error during database disconnect: {e}")
    
    async def is_connected(self) -> bool:
        """Check if database is connected"""
        try:
            {% if config.database.database_type.value == "postgresql" -%}
            if not self.pool:
                return False
            async with self.pool.acquire() as conn:
                await conn.fetchval("SELECT 1")
            return True
            {% elif config.database.database_type.value == "mongodb" -%}
            if not self.client:
                return False
            await self.client.admin.command('ping')
            return True
            {% elif config.database.database_type.value == "redis" -%}
            if not self.redis:
                return False
            await self.redis.ping()
            return True
            {% elif config.database.database_type.value == "in_memory" -%}
            return self.connected
            {% endif -%}
        except Exception:
            return False


# Global database instance
database = Database()


