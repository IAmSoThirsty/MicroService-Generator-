class BaseRepository:
    """Base repository with common database operations"""
    
    def __init__(self):
        self.db = database
    
    async def _execute_with_metrics(self, operation: str, func):
        """Execute database operation with metrics"""
        start_time = time.time()
        try:
            result = await func()
            duration = time.time() - start_time
            DB_QUERY_DURATION.labels(operation=operation).observe(duration)
            return result
        except Exception as e:
            DB_ERRORS.labels(operation=operation, error_type=type(e).__name__).inc()
            raise


class ItemRepository(BaseRepository):
    """Item repository"""
    
    {% if config.database.database_type.value == "postgresql" -%}
    async def list(self, offset: int = 0, limit: int = 20) -> Tuple[List[Item], int]:
        """List items with pagination"""
        async def _query():
            async with self.db.pool.acquire() as conn:
                # Get total count
                total = await conn.fetchval("SELECT COUNT(*) FROM items")
                
                # Get items
                rows = await conn.fetch(
                    """
                    SELECT id, name, description, created_at, updated_at
                    FROM items
                    ORDER BY created_at DESC
                    LIMIT $1 OFFSET $2
                    """,
                    limit, offset
                )
                
                items = [Item(**dict(row)) for row in rows]
                return items, total
        
        return await self._execute_with_metrics("list", _query)
    
    async def get(self, item_id: UUID) -> Optional[Item]:
        """Get item by ID"""
        async def _query():
            async with self.db.pool.acquire() as conn:
                row = await conn.fetchrow(
                    """
                    SELECT id, name, description, created_at, updated_at
                    FROM items
                    WHERE id = $1
                    """,
                    item_id
                )
                return Item(**dict(row)) if row else None
        
        return await self._execute_with_metrics("get", _query)
    
    async def create(self, item: Item) -> Item:
        """Create item"""
        async def _query():
            async with self.db.pool.acquire() as conn:
                await conn.execute(
                    """
                    INSERT INTO items (id, name, description, created_at, updated_at)
                    VALUES ($1, $2, $3, $4, $5)
                    """,
                    item.id, item.name, item.description, item.created_at, item.updated_at
                )
                return item
        
        return await self._execute_with_metrics("create", _query)
    
    async def update(self, item_id: UUID, updates: Dict[str, Any]) -> Item:
        """Update item"""
        async def _query():
            set_clauses = []
            values = []
            for i, (key, value) in enumerate(updates.items(), start=1):
                set_clauses.append(f"{key} = ${i}")
                values.append(value)
            
            values.append(item_id)
            
            async with self.db.pool.acquire() as conn:
                row = await conn.fetchrow(
                    f"""
                    UPDATE items
                    SET {', '.join(set_clauses)}
                    WHERE id = ${len(values)}
                    RETURNING id, name, description, created_at, updated_at
                    """,
                    *values
                )
                return Item(**dict(row)) if row else None
        
        return await self._execute_with_metrics("update", _query)
    
    async def delete(self, item_id: UUID) -> None:
        """Delete item"""
        async def _query():
            async with self.db.pool.acquire() as conn:
                await conn.execute("DELETE FROM items WHERE id = $1", item_id)
        
        await self._execute_with_metrics("delete", _query)
    
    {% elif config.database.database_type.value == "in_memory" -%}
    async def list(self, offset: int = 0, limit: int = 20) -> Tuple[List[Item], int]:
        """List items with pagination"""
        items_list = list(self.db.data.get("items", {}).values())
        items_list.sort(key=lambda x: x.created_at, reverse=True)
        total = len(items_list)
        paginated = items_list[offset:offset + limit]
        return paginated, total
    
    async def get(self, item_id: UUID) -> Optional[Item]:
        """Get item by ID"""
        return self.db.data.get("items", {}).get(str(item_id))
    
    async def create(self, item: Item) -> Item:
        """Create item"""
        if "items" not in self.db.data:
            self.db.data["items"] = {}
        self.db.data["items"][str(item.id)] = item
        return item
    
    async def update(self, item_id: UUID, updates: Dict[str, Any]) -> Item:
        """Update item"""
        item = await self.get(item_id)
        if item:
            for key, value in updates.items():
                setattr(item, key, value)
        return item
    
    async def delete(self, item_id: UUID) -> None:
        """Delete item"""
        self.db.data.get("items", {}).pop(str(item_id), None)
    {% endif -%}
